{{- $host := env "DOTFILES_HOST" | default .chezmoi.hostname -}}
{{- $email := env "DOTFILES_EMAIL" -}}
{{- if not $email -}}
{{- $email = promptStringOnce . "email" "Git email" -}}
{{- end -}}
sourceDir = "{{ .chezmoi.sourceDir }}"

[data]
name = "Yuan"
host = {{ $host | quote }}
email = {{ $email | quote }}
editor = "{{ env "EDITOR" | default "nvim" }}"
sshAgent = "system"
{{ if or (eq $host "win-desktop") (eq $host "SARGERAS") }}
shell = "pwsh"
terminal = "windows-terminal"
installGuiApps = true
{{ else if eq $host "work-mac" }}
shell = "zsh"
terminal = "ghostty"
installGuiApps = false
{{ else if eq $host "macbook-pro" }}
shell = "zsh"
terminal = "ghostty"
installGuiApps = true
{{ else if eq $host "linux-devbox" }}
shell = "zsh"
terminal = "wezterm"
installGuiApps = false
{{ else }}
shell = "{{ if eq .chezmoi.os "windows" }}pwsh{{ else }}zsh{{ end }}"
terminal = "{{ if eq .chezmoi.os "windows" }}windows-terminal{{ else }}wezterm{{ end }}"
installGuiApps = true
{{ end }}
