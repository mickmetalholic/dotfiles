[user]
	name = {{ .name | quote }}
	email = {{ .email | quote }}

[init]
	defaultBranch = main

[core]
	editor = {{ .editor | quote }}
	excludesfile = ~/.gitignore_global

[pull]
	rebase = false

[push]
	autoSetupRemote = true

[includeIf "gitdir:~/work/"]
	path = ~/.config/git/config-work

[includeIf "gitdir:~/personal/"]
	path = ~/.config/git/config-personal
